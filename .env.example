# Arogya AI Health OS - Local Secure Environment Configuration Template
# Copy this file to a new file named '.env' in the same folder, and input your Gemini API Key.
# The '.env' file is automatically ignored by Git (configured in .gitignore) to keep your credentials safe.

# Your Google Gemini API Key (Required for Cloud Gemini Premium mode)
GEMINI_API_KEY=your_gemini_api_key_here
